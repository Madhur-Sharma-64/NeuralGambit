// =============================================
// ZOBRIST HASHING
// =============================================
struct Zobrist {
    uint64_t pieces[2][6][64]; // [color][piece][square]
    uint64_t sideToMove;
    uint64_t castling[4];
    uint64_t enPassant[8];

    Zobrist() {
        std::mt19937_64 rng(123456789ULL);
        for (auto& c : pieces)
            for (auto& p : c)
                for (auto& s : p)
                    s = rng();
        sideToMove = rng();
        for (auto& c : castling)  c = rng();
        for (auto& e : enPassant) e = rng();
    }

    uint64_t hash(const Board& board) const {
        uint64_t h = 0;
        for (int sq = 0; sq < 64; sq++) {
            Piece p = board.at(Square(sq));
            if (p != Piece::NONE) {
                int color  = (p.color() == Color::WHITE) ? 0 : 1;
                int ptype  = (int)p.type().internal();
                h ^= pieces[color][ptype][sq];
            }
        }
        if (board.sideToMove() == Color::BLACK)
            h ^= sideToMove;
        return h;
    }
} zobrist;

// =============================================
// TRANSPOSITION TABLE
// =============================================
enum TTFlag { EXACT, LOWERBOUND, UPPERBOUND };

struct TTEntry {
    uint64_t hash;
    int      depth;
    int      score;
    TTFlag   flag;
    Move     bestMove;
};

const int TT_SIZE = 1 << 22; // ~4 million entries
std::vector<TTEntry> TT(TT_SIZE);

void tt_store(uint64_t hash, int depth, int score, TTFlag flag, Move best) {
    int idx = hash % TT_SIZE;
    TT[idx] = {hash, depth, score, flag, best};
}

bool tt_probe(uint64_t hash, int depth, int alpha, int beta,
              int& score, Move& bestMove) {
    int idx = hash % TT_SIZE;
    TTEntry& e = TT[idx];
    if (e.hash != hash) return false;
    bestMove = e.bestMove;
    if (e.depth >= depth) {
        if (e.flag == EXACT) { score = e.score; return true; }
        if (e.flag == LOWERBOUND && e.score >= beta)  { score = e.score; return true; }
        if (e.flag == UPPERBOUND && e.score <= alpha) { score = e.score; return true; }
    }
    return false;
}

